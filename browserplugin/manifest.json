{
  "manifest_version": 3,
  "name": "CS:GO Demo Viewer for Faceit",
  "version": "1.0.0",
  "description": "Add a button to Faceit match pages to view CS:GO demos in your demo viewer",

  "permissions": ["activeTab", "storage"],

  "host_permissions": ["*://*.faceit.com/*"],

  "content_scripts": [
    {
      "matches": ["*://*.faceit.com/*/room/*"],
      "js": ["content-script.js"],
      "css": ["content-styles.css"],
      "run_at": "document_end"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "CS:GO Demo Viewer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_page": "options.html",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  }
}
